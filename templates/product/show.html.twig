{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}

<div class="card p-4 shadow-sm">

    <h1>{{ product.name }}</h1>

    <p class="text-muted">{{ product.description }}</p>

    <h3 class="text-success">{{ product.priceHT }} €</h3>
    <a href="{{ path('cart_add', {id: product.id}) }}" class="btn btn-primary mt-3">
        Ajouter au panier
    </a>
    <a href="{{ path('product_list') }}" class="btn btn-secondary mt-3">
        ← Retour
    </a>

</div>

{% endblock %}
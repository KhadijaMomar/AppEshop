<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Ma Boutique{% endblock %}</title>

    {# Bootstrap CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
        }
        .navbar {
            margin-bottom: 20px;
        }
        .card {
            border-radius: 10px;
        }
    </style>
</head>

<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
            <a class="navbar-brand me-3" href="{{ path('home') }}">🛍️ Ma Boutique</a>
            <a class="btn btn-outline-light me-2" href="{{ path('product_list') }}">Produits</a>
            <a class="btn btn-outline-light me-2" href="{{ path('app_categories') }}">Catégories</a>
            <a class="btn btn-outline-light" href="{{ path('cart_index') }}">🛒 Panier</a>
        </div>

        <div class="d-flex align-items-center">
           {% if app.user %}
                <span class="text-white me-2">Bonjour, {{ app.user.name }} !</span>

                <a class="btn btn-outline-light me-2" href="{{ path('app_profile') }}">
                    Mon profil
                </a>

                <a class="btn btn-outline-light" href="{{ path('app_logout') }}">
                    Se déconnecter
                </a>
            {% else %}
                <a class="btn btn-outline-light" href="{{ path('app_login') }}">Se connecter</a>
            {% endif %}
        </div>
    </div>
</nav>

<div class="container">
    {% block body %}{% endblock %}
</div>

{# Optionnel : JS Bootstrap #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
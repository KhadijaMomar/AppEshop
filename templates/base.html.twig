<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Ma Boutique{% endblock %}</title>

    {# Bootstrap CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
        }
        .navbar {
            margin-bottom: 20px;
        }
        .card {
            border-radius: 10px;
        }
        @media (max-width: 991.98px) {
    .navbar-nav .btn {
        margin-bottom: 10px;
        display: block;
        width: 100%;
        text-align: left;
    }
    .user-info {
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px solid #444;
    }
}
    </style>
</head>

<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">🛍️ Ma Boutique</a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="btn btn-outline-light me-lg-2" href="{{ path('product_list') }}">Produits</a>
                </li>
                <li class="nav-item">
                    <a class="btn btn-outline-light me-lg-2" href="{{ path('app_categories') }}">Catégories</a>
                </li>
                <li class="nav-item">
                    <a class="btn btn-outline-light" href="{{ path('cart_index') }}">🛒 Panier</a>
                </li>
            </ul>

            <div class="d-flex flex-column flex-lg-row align-items-lg-center user-info">
               {% if app.user %}
                    <span class="text-white me-lg-3 mb-2 mb-lg-0">👤 {{ app.user.name }}</span>
                    <a class="btn btn-outline-light me-lg-2 mb-2 mb-lg-0" href="{{ path('app_profile') }}">Mon profil</a>
                    <a class="btn btn-outline-info" href="{{ path('app_logout') }}">Se déconnecter</a>
                {% else %}
                    <a class="btn btn-outline-light" href="{{ path('app_login') }}">Se connecter</a>
               {% endif %}
            </div>
        </div>
    </div>
</nav>

<div class="container">
    {% block body %}{% endblock %}
</div>

{# Optionnel : JS Bootstrap #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
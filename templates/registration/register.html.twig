{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<style>
    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #ddd;
        transition: all 0.3s ease;
        box-shadow: none;
    }

    .form-control:focus {
        border-color: #4a90e2;
        box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.2);
    }

    label {
        font-weight: 500;
        margin-bottom: 5px;
    }

    .card {
        border: none;
        border-radius: 20px;
    }

    .btn-primary {
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-primary:hover {
        background-color: #357abd;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    
    <div class="card shadow-lg p-4" style="width: 100%; max-width: 500px;">
        
        <div class="text-center mb-4">
            <h2 class="fw-bold">Créer un compte</h2>
            <p class="text-muted">Inscription rapide et sécurisée</p>
        </div>

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

        <!-- Prénom + Nom -->
        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_label(registrationForm.firstName) }}
                {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.firstName) }}
            </div>
            <div class="col-md-6 mb-3">
                {{ form_label(registrationForm.name) }}
                {{ form_widget(registrationForm.name, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.name) }}
            </div>
        </div>

        <!-- Email -->
        <div class="mb-3">
            {{ form_label(registrationForm.email) }}
            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(registrationForm.email) }}
        </div>

        <!-- Téléphone -->
        <div class="mb-3">
            {{ form_label(registrationForm.phone) }}
            {{ form_widget(registrationForm.phone, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(registrationForm.phone) }}
        </div>

        <!-- Date de naissance -->
        <div class="mb-3">
            {{ form_label(registrationForm.birthDate) }}
            {{ form_widget(registrationForm.birthDate, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(registrationForm.birthDate) }}
        </div>

        <!-- Mot de passe -->
        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_label(registrationForm.plainPassword.first) }}
                {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.plainPassword.first) }}
            </div>
            <div class="col-md-6 mb-3">
                {{ form_label(registrationForm.plainPassword.second) }}
                {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.plainPassword.second) }}
            </div>
        </div>

        <!-- Bouton -->
        <button type="submit" class="btn btn-primary w-100 mt-3">
            S’inscrire
        </button>

        {{ form_end(registrationForm) }}

        <hr class="my-4">

        <!-- Lien connexion -->
        <div class="text-center">
            <p class="mb-0">Déjà un compte ?</p>
            <a href="{{ path('app_login') }}" class="btn btn-outline-secondary mt-2">
                Se connecter
            </a>
        </div>

    </div>
</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<style>

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #ddd;
        transition: all 0.3s ease;
        box-shadow: none;
    }

    .form-control:focus {
        border-color: #4a90e2;
        box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.2);
    }

    label {
        font-weight: 500;
        margin-bottom: 5px;
    }

    .card {
        border: none;
        border-radius: 20px;
    }

    .btn-primary {
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-primary:hover {
        background-color: #357abd;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    
    <div class="card shadow-lg p-4" style="width: 100%; max-width: 500px;">
        
        <div class="text-center mb-4">
            <h2 class="fw-bold">Connexion</h2>
            <p class="text-muted">Accédez à votre espace sécurisé</p>
        </div>

        <form method="post">
            {% if error %}
                <div class="alert alert-danger" style="border-radius: 10px;">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3 text-center">
                    Vous êtes connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>, 
                    <a href="{{ logout_path() }}" class="text-decoration-none">Déconnexion</a>
                </div>
            {% endif %}

            <div class="mb-3">
                <label for="inputEmail">Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus placeholder="exemple@mail.com">
            </div>

            <div class="mb-3">
                <label for="inputPassword">Mot de passe</label>
                <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required placeholder="••••••••">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="checkbox mb-3 ms-1">
                <label>
                    <input type="checkbox" name="_remember_me"> Se souvenir de moi
                </label>
            </div>

            <button class="btn btn-primary w-100 mt-2" type="submit">
                Se connecter
            </button>
        </form>

        <hr class="my-4">

        <div class="text-center">
            <p class="mb-0">Pas encore de compte ?</p>
            <a href="{{ path('app_register') }}" class="btn btn-outline-secondary mt-2 w-100" style="border-radius: 10px;">
                Créer un compte
            </a>
        </div>

    </div>
</div>
{% endblock %}